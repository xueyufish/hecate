# =============================================================================
# Database — PostgreSQL 16 (async driver)
# =============================================================================
# Async connection string for SQLAlchemy
DATABASE_URL=postgresql+asyncpg://hecate:hecate@localhost:5432/hecate
# PostgreSQL password (used by docker-compose)
POSTGRES_PASSWORD=hecate

# =============================================================================
# Vector Store — Qdrant
# =============================================================================
# Qdrant endpoint for knowledge base embeddings retrieval
QDRANT_URL=http://localhost:6333

# =============================================================================
# Object Storage — MinIO
# =============================================================================
# MinIO endpoint for document / file storage
MINIO_URL=localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
# Default bucket name for Hecate assets
MINIO_BUCKET=hecate

# =============================================================================
# LLM Provider API Keys
# =============================================================================
# OpenAI-compatible API key (used by LiteLLM for routing)
OPENAI_API_KEY=
# Anthropic API key
ANTHROPIC_API_KEY=

# =============================================================================
# Security & Rate Limiting
# =============================================================================
# Comma-separated API keys for Hecate management API authentication
HECATE_API_KEYS=
# Enable LLM Guard input/output scanning (true/false)
LLM_GUARD_ENABLED=true
# Max requests per minute per client
RATE_LIMIT_RPM=60
