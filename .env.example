# =============================================================================
# Database — PostgreSQL 16 (async driver)
# =============================================================================
# Async connection string for SQLAlchemy
DATABASE_URL=postgresql+asyncpg://hecate:hecate@localhost:5432/hecate
# PostgreSQL password (used by docker-compose)
POSTGRES_PASSWORD=hecate

# =============================================================================
# Vector Store — pluggable backends
# =============================================================================
# Backend selector: "qdrant" or "chroma"
VECTOR_STORE_TYPE=qdrant
# Qdrant endpoint (used when VECTOR_STORE_TYPE=qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
# Chroma persistence directory (used when VECTOR_STORE_TYPE=chroma)
CHROMA_PERSIST_DIR=./data/chroma

# =============================================================================
# Object Storage — MinIO
# =============================================================================
# MinIO endpoint for document / file storage
MINIO_URL=localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
# Default bucket name for Hecate assets
MINIO_BUCKET=hecate

# =============================================================================
# LLM Provider API Keys
# =============================================================================
# OpenAI-compatible API key (used by LiteLLM for routing)
OPENAI_API_KEY=
# Anthropic API key
ANTHROPIC_API_KEY=

# =============================================================================
# Security & Rate Limiting
# =============================================================================
# Comma-separated API keys for Hecate management API authentication
HECATE_API_KEYS=
# Enable LLM Guard input/output scanning (true/false)
LLM_GUARD_ENABLED=true
# Max requests per minute per client
RATE_LIMIT_RPM=60

# =============================================================================
# MCP (Model Context Protocol)
# =============================================================================
# Enable MCP Server (exposes Hecate capabilities as MCP tools)
MCP_SERVER_ENABLED=false
# MCP Server bind host
MCP_SERVER_HOST=0.0.0.0
# MCP Server bind port
MCP_SERVER_PORT=8000
# MCP auth mode: "api_key", "jwt", or "none"
MCP_AUTH_TYPE=api_key
# MCP transport: "http" (Streamable HTTP)
MCP_TRANSPORT=http
# MCP Client connection timeout in seconds
MCP_CLIENT_TIMEOUT=30

# Context Offloading (1.3.15b): write overflow conversation context to the
# AgentEnvironment filesystem instead of discarding it. The agent can retrieve
# offloaded content via the read_file tool.
CONTEXT_OFFLOAD_ENABLED=true
# Minimum token overflow that triggers offload. Prevents trivially small writes.
CONTEXT_OFFLOAD_THRESHOLD_TOKENS=6000
